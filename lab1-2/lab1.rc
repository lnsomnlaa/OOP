#include <windows.h>
#include "resource.h"

IDD_PARAMS DIALOGEX 0, 0, 250, 70
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Enter parameters"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    EDITTEXT        IDC_PARAMS_EDIT, 7, 15, 236, 14, ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK", IDOK, 65, 45, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 135, 45, 50, 14
END